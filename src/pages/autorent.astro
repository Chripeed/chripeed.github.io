---
import AutorentNavbar from "../layouts/navbar_autorent_layout.astro";
import bg from "/Galerii/Auto/galerii4.jpg?url";
import bg2 from "/Galerii/Auto/galerii6.jpg?url";
---

<style>
  .clip-path {
    clip-path: polygon(0 0, 100% 0%, 100% 85%, 0 100%);
  }

  .clip-path-reverse {
    clip-path: polygon(0 15%, 100% 0, 100% 100%, 0 100%);
  }

  @media (min-width: 768px) {
    .clip-path-reverse {
      clip-path: polygon(0 7.5%, 100% 0, 100% 100%, 0 100%);
    }
  }
</style>

<AutorentNavbar>
  <div class="relative w-full mt-4">
    <!-- Background Image Section -->
    <div
      class="relative flex items-center justify-center h-[24rem] w-full bg-cover bg-center bg-no-repeat clip-path"
      style={{ backgroundImage: `url(${bg})` }}
    >
      <h1
        class="mx-4 my-4 mt-16 text-4xl font-bold text-center text-pure-white font-Florentino"
      >
        Rendi luksuslik Mercedes-Benz
      </h1>
    </div>

    <!-- Main Content Section -->
    <div class="flex flex-col w-full mt-4 md:flex-row">
      <!-- Text Content -->
      <div class="flex-1 p-8 mt-4 md:justify-center">
        <div class="max-w-lg mx-auto font-SortsMillGoudy text-onyx-black">
          <h2 class="text-2xl font-bold text-center md:text-left">
            Pulmaautode rentimine
          </h2>
          <div class="mt-8 text-lg">
            <p class="mb-4">
              Meie WedLuxis teeme kõik endast oleneva, et muuta teie pulmad
              eksklusiivse pulmaauto rentimisega unustamatuks kogemuseks.
            </p>
            <p class="mb-4">
              Pakume oma teenuseid terve Eesti piires ja täpse hinnapakkumise
              teeme teile, kui oleme pulmasõiduga seotud üksikasjad läbi
              arutanud.
            </p>
            <p class="mb-12">
              Lähemalt tutvuge meie <a
                href="/autorent/hinnakiri"
                class="font-black text-deep-black">hinnakirjaga</a
              > ja võtke meiega <a
                href="/autorent/kontakt"
                class="font-black text-deep-black">ühendust</a
              >.
            </p>
          </div>
        </div>
      </div>
      <!-- Image Section for Mobile View -->
      <div
        class="bg-cover bg-center bg-no-repeat clip-path-reverse w-full h-[24rem] md:flex-1"
        style={{ backgroundImage: `url(${bg2})` }}
      >
      </div>
    </div>
  </div>
</AutorentNavbar>
